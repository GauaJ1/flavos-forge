# Flavos Forge - Environment Configuration Template

# Server Settings
PORT=5000
NODE_ENV=development

# Security Keys (Generate strong keys for production, e.g. using `openssl rand -hex 32`)
# JWT secret for authentication session tokens
JWT_SECRET_KEY=your_jwt_secret_key_here_at_least_32_chars_long

# Journal Encryption Key (Must be exactly a 32-byte hex string: 64 hex characters)
# Separate from JWT key to guarantee cryptographic separation of concerns
JOURNAL_ENC_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# Database Configuration (Neon PostgreSQL)
# Always use pgbouncer and limit connections on serverless environments like Neon
DATABASE_URL="postgresql://user:password@ep-host-name.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&connection_limit=1"

# CORS Configuration
# Comma-separated list of allowed origins. Do NOT use '*' in production.
CORS_ORIGINS="http://localhost:5173,https://forge.flavoscompany.xyz"
